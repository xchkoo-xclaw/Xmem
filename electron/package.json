{
  "name": "xmem-desktop",
  "version": "0.1.0",
  "main": "main.js",
  "scripts": {
    "dev": "cross-env VITE_DEV_SERVER=http://localhost:5173 electron .",
    "dev:no-devtools": "cross-env VITE_DEV_SERVER=http://localhost:5173 OPEN_DEVTOOLS=false electron .",
    "start": "electron .",
    "build:frontend": "npm --prefix ../frontend install && cross-env VITE_API_URL=https://xmem.top/api npm --prefix ../frontend run build",
    "pack": "npm run build:frontend && electron-builder --dir",
    "dist": "npm run build:frontend && electron-builder"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^33.1.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.xmem.desktop",
    "productName": "Xmem",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend-dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
