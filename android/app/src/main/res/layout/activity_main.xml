<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xmem_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xmem"
            android:textColor="@color/xmem_text"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="自动截图上传记账原型"
            android:textColor="@color/xmem_text_muted"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_title"
                android:textColor="@color/xmem_text"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/input_base_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card"
                android:hint="@string/settings_hint_url"
                android:padding="12dp"
                android:textColor="@color/xmem_text"
                android:textColorHint="@color/xmem_text_muted"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/input_token"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card"
                android:hint="@string/settings_hint_token"
                android:padding="12dp"
                android:textColor="@color/xmem_text"
                android:textColorHint="@color/xmem_text_muted"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button"
                android:text="@string/settings_save"
                android:textColor="@color/xmem_on_accent"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_capture"
                android:textColor="@color/xmem_text"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/status_idle"
                android:textColor="@color/xmem_text_muted"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_capture"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_button"
                android:text="@string/action_capture"
                android:textColor="@color/xmem_on_accent"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
