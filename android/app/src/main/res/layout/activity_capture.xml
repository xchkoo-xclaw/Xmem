<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/xmem_bg"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="@dimen/spacing_lg">

    <TextView
        android:id="@+id/capture_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/capture_permission"
        android:textColor="@color/xmem_text"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/capture_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/capture_working"
        android:textColor="@color/xmem_text_muted"
        android:textSize="12sp" />
</LinearLayout>
